<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003" ToolsVersion="4.0">
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <SchemaVersion>2.0</SchemaVersion>
    <ProjectGuid>f741de89-814e-4cfc-900b-6b33d859ebae</ProjectGuid>
    <ProjectHome>.</ProjectHome>
    <StartupFile>app.py</StartupFile>
    <SearchPath>.</SearchPath>
    <WorkingDirectory>.</WorkingDirectory>
    <OutputPath>.</OutputPath>
    <Name>Salinity 2</Name>
    <RootNamespace>Salinity 2</RootNamespace>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Debug' ">
    <DebugSymbols>true</DebugSymbols>
    <EnableUnmanagedDebugging>false</EnableUnmanagedDebugging>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Release' ">
    <DebugSymbols>true</DebugSymbols>
    <EnableUnmanagedDebugging>false</EnableUnmanagedDebugging>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="app.py" />
    <Compile Include="config.py" />
    <Compile Include="data.py" />
    <Compile Include="data_loader.py" />
    <Compile Include="evaluate.py" />
    <Compile Include="models.py" />
    <Compile Include="pipeline.py" />
    <Compile Include="preprocessing.py" />
    <Compile Include="sampling.py" />
    <Compile Include="algo_params.py" />
    <Compile Include="Salinity_2.py" />
    <Compile Include="threshold_search.py" />
    <Compile Include="train.py" />
    <Compile Include="tuning.py" />
    <Compile Include="ui_controls.py" />
  </ItemGroup>
  <ItemGroup>
    <Content Include="Data.xlsx" />
    <Content Include="requirements.txt" />
    <Content Include="run_ui.bat" />
    <Content Include="run_cli.bat" />
  </ItemGroup>
  <Import Project="$(MSBuildExtensionsPath32)\Microsoft\VisualStudio\v$(VisualStudioVersion)\Python Tools\Microsoft.PythonTools.targets" />
  <Target Name="BeforeBuild" />
  <Target Name="AfterBuild" />
</Project>
